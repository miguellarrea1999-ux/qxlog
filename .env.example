# Copy this file to `.env` and fill in your Supabase project values.
# `.env` is git-ignored — never commit real keys.
#
# Find these in the Supabase dashboard: Project Settings → API.
# The anon (public) key is safe to ship to the browser ONLY when Row-Level
# Security is enabled on every table (see supabase/enable-rls.sql).

VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
